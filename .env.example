# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ps_campaign_manager

# Auth
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# File Storage
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Proxycurl
PROXYCURL_API_KEY=your-proxycurl-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Salesforce
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_REFRESH_TOKEN=your-salesforce-refresh-token
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# SalesLoft
SALESLOFT_API_KEY=your-salesloft-api-key
SALESLOFT_CLIENT_ID=your-salesloft-client-id
SALESLOFT_CLIENT_SECRET=your-salesloft-client-secret

# Unipile (LinkedIn Messaging)
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_BASE_URL=https://api1.unipile.com:13111
UNIPILE_WEBHOOK_SECRET=your-unipile-webhook-secret

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
