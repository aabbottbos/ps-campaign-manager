# ============================================
# PS Campaign Manager - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ============================================
# Database (REQUIRED)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/ps_campaign_manager

# ============================================
# Authentication (REQUIRED for Sprint 1)
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# File Storage (REQUIRED for Sprint 2)
# ============================================
# Vercel Blob token from https://vercel.com/account/tokens
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token

# ============================================
# Data Enrichment (REQUIRED for Sprint 3)
# ============================================
# Apify API token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your-apify-api-token

# Inngest (background jobs) from https://www.inngest.com/
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ProxyCurl (alternative enrichment provider)
# PROXYCURL_API_KEY=your-proxycurl-api-key

# ============================================
# AI Message Generation (OPTIONAL for Sprint 4)
# ============================================
# Anthropic Claude API from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# Salesforce CRM (OPTIONAL for Sprint 5)
# ============================================
# Salesforce OAuth from https://developer.salesforce.com/
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_REFRESH_TOKEN=your-salesforce-refresh-token
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# ============================================
# SalesLoft CRM (OPTIONAL for Sprint 6)
# ============================================
# SalesLoft API from https://app.salesloft.com/app/settings/integrations
SALESLOFT_API_KEY=your-salesloft-api-key

# ============================================
# LinkedIn Automation (OPTIONAL for Sprint 7)
# ============================================
# Unipile API from https://unipile.com/
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_BASE_URL=https://api1.unipile.com:13111
